.page {
  padding: 20rpx 0 60rpx;
  min-height: 100vh;
  background: #F5F6FA;
}

/* 周期切换 */
.period-bar {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 0 24rpx 20rpx;
}
.period-item {
  padding: 12rpx 36rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #FFFFFF;
  border: 2rpx solid transparent;
}
.period-item.active {
  background: #E8F5E9;
  color: #00C853;
  border-color: #00C853;
  font-weight: 500;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx 0;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.stat-box {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #F0F0F0;
}
.stat-box:last-child {
  border-right: none;
}
.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #00C853;
  margin-bottom: 8rpx;
}
.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 图表卡片 */
.chart-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.chart-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.chart-unit {
  font-size: 22rpx;
  color: #999;
}
.chart-wrap {
  width: 100%;
  position: relative;
}
.chart-tooltip {
  position: absolute;
  background: rgba(0,0,0,0.8);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  pointer-events: none;
  z-index: 10;
  white-space: nowrap;
}
.chart-empty {
  text-align: center;
  padding: 80rpx 0;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #bbb;
}

/* 参考范围 */
.ref-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.ref-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.ref-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F6FA;
}
.ref-item:last-child {
  border-bottom: none;
}
.ref-label {
  font-size: 26rpx;
  color: #666;
}
.ref-value {
  font-size: 26rpx;
  color: #00C853;
  font-weight: 500;
}

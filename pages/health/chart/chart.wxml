<view class="page">
  <!-- 周期切换 -->
  <view class="period-bar">
    <view class="period-item {{period === item.key ? 'active' : ''}}" wx:for="{{periods}}" wx:key="key" data-key="{{item.key}}" bindtap="onSelectPeriod">{{item.label}}</view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stat-box">
      <text class="stat-num">{{stats.max}}</text>
      <text class="stat-label">最高{{typeName}}</text>
    </view>
    <view class="stat-box">
      <text class="stat-num">{{stats.min}}</text>
      <text class="stat-label">最低{{typeName}}</text>
    </view>
    <view class="stat-box">
      <text class="stat-num">{{stats.avg}}</text>
      <text class="stat-label">平均{{typeName}}</text>
    </view>
  </view>

  <!-- 图表区域 -->
  <view class="chart-card" id="chart-container">
    <view class="chart-header">
      <text class="chart-title">{{typeName}}趋势</text>
      <text class="chart-unit">单位：{{unit}}</text>
    </view>
    <view class="chart-wrap">
      <canvas canvas-id="trendChart" style="height: 400rpx;"></canvas>
    </view>
    <view class="chart-empty" wx:if="{{records.length < 2}}">
      <text class="empty-text">数据不足，无法生成图表</text>
      <text class="empty-hint">至少需要2条记录</text>
    </view>
  </view>

  <!-- 参考范围 -->
  <view class="ref-card" wx:if="{{type === 'blood_sugar' || type === 'uric_acid'}}">
    <text class="ref-title">参考范围</text>
    <view class="ref-item" wx:if="{{type === 'blood_sugar'}}">
      <text class="ref-label">空腹血糖</text>
      <text class="ref-value">3.9 ~ 6.1 mmol/L</text>
    </view>
    <view class="ref-item" wx:if="{{type === 'uric_acid'}}">
      <text class="ref-label">尿酸（男性）</text>
      <text class="ref-value">208 ~ 428 μmol/L</text>
    </view>
  </view>
</view>

.page {
  padding: 20rpx 0 60rpx;
  min-height: 100vh;
  background: #F5F6FA;
}

.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 24rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.section {
  margin-bottom: 36rpx;
}
.section:last-child {
  margin-bottom: 0;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.section-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 选项组 */
.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.option-item {
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F6FA;
  border: 2rpx solid transparent;
}
.option-item.active {
  background: #E8F5E9;
  color: #00C853;
  border-color: #00C853;
}

/* BMI结果显示 */
.bmi-result {
  background: #F5F6FA;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  text-align: center;
}
.bmi-title {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}
.bmi-value {
  display: block;
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.bmi-category {
  display: inline-block;
  font-size: 26rpx;
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
}
.bmi-category.normal {
  background: #E8F5E9;
  color: #388E3C;
}
.bmi-category.low {
  background: #FFF3E0;
  color: #F57C00;
}
.bmi-category.high {
  background: #FFEBEE;
  color: #D32F2F;
}

/* 保存按钮 */
.btn-wrap {
  padding: 0 24rpx;
}
.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #00C853, #69F0AE);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

/* 说明 */
.tips {
  padding: 30rpx 48rpx;
}
.tips-title {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}
.tips-item {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

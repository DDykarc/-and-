<!-- 添加/编辑商品页面 -->
<view class="page">

  <view class="form-card card">
    <view class="form-title">{{isEdit ? '编辑物品' : '添加新物品'}}</view>

    <!-- 物品名称 -->
    <view class="form-group">
      <text class="form-label">物品名称</text>
      <input class="input-field" type="text" placeholder="例如：iPhone 16" value="{{name}}" bindinput="onNameInput" maxlength="30" />
    </view>

    <!-- 购买价格 -->
    <view class="form-group">
      <text class="form-label">购买价格 (¥)</text>
      <view class="price-input-wrap">
        <text class="price-prefix">¥</text>
        <input class="input-field price-input" type="digit" placeholder="输入价格" value="{{price}}" bindinput="onPriceInput" />
      </view>
    </view>

    <!-- 购买日期 -->
    <view class="form-group">
      <text class="form-label">购买日期</text>
      <picker mode="date" value="{{buyDate}}" bindchange="onDateChange" end="{{today}}">
        <view class="input-field date-picker">
          <text class="{{buyDate ? 'date-text' : 'date-placeholder'}}">{{buyDate || '请选择购买日期'}}</text>
          <text class="date-arrow">▶</text>
        </view>
      </picker>
    </view>

    <!-- 分类 -->
    <view class="form-group">
      <text class="form-label">分类</text>
      <view class="category-selector">
        <view class="category-option {{category === item.name ? 'active' : ''}}" wx:for="{{categories}}" wx:key="name" data-name="{{item.name}}" bindtap="onCategorySelect">
          <text class="cat-icon">{{item.icon}}</text>
          <text class="cat-text">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-group">
      <text class="form-label">备注（选填）</text>
      <input class="input-field" type="text" placeholder="例如：二手、官方翻新" value="{{note}}" bindinput="onNoteInput" maxlength="50" />
    </view>

    <!-- 预览信息 -->
    <view class="preview-section" wx:if="{{name && price && buyDate}}">
      <view class="preview-divider"></view>
      <view class="preview-title">使用情况预览</view>
      <view class="preview-row">
        <text class="preview-label">已用天数</text>
        <text class="preview-value">{{previewDays}} 天</text>
      </view>
      <view class="preview-row">
        <text class="preview-label">日均成本</text>
        <text class="preview-value preview-cost">¥{{previewDailyCost}} /天</text>
      </view>
    </view>

    <!-- 保存按钮 -->
    <button class="btn-primary save-btn" bindtap="onSave" disabled="{{!canSave}}" loading="{{saving}}">
      {{isEdit ? '保存修改' : '添加物品'}}
    </button>

    <!-- 删除按钮（编辑模式） -->
    <button class="btn-delete" wx:if="{{isEdit}}" bindtap="onDelete" hover-class="btn-delete-hover">
      删除此物品
    </button>
  </view>

</view>

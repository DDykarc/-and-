<!-- 折线图/柱状图页面 -->
<view class="page">

  <!-- ===== 全部物品模式 ===== -->
  <block wx:if="{{isAllMode}}">
    <!-- 统计头部 -->
    <view class="all-header card">
      <view class="all-header-top">
        <text class="all-title">全部物品对比</text>
        <text class="all-subtitle">当前每件物品的日均成本</text>
      </view>
      <view class="all-stats">
        <view class="all-stat-item">
          <text class="all-stat-num">{{allItems.length}}</text>
          <text class="all-stat-label">件物品</text>
        </view>
        <view class="all-stat-divider"></view>
        <view class="all-stat-item">
          <text class="all-stat-num all-stat-cost">¥{{allTotal}}</text>
          <text class="all-stat-label">今日总折旧</text>
        </view>
        <view class="all-stat-divider"></view>
        <view class="all-stat-item">
          <text class="all-stat-num all-stat-high">¥{{allHighest}}</text>
          <text class="all-stat-label">最高单件</text>
        </view>
      </view>
    </view>

    <!-- 柱状图 -->
    <view class="chart-wrapper card">
      <canvas type="2d" id="costChart" class="chart-canvas"></canvas>
    </view>

    <!-- 排名表 -->
    <view class="data-table card">
      <view class="table-title">按日均成本排名</view>
      <view class="table-header">
        <text class="th th-rank">#</text>
        <text class="th th-name">物品</text>
        <text class="th th-all-days">天数</text>
        <text class="th th-all-cost">日均</text>
      </view>
      <view class="table-body">
        <view class="table-row" wx:for="{{allItems}}" wx:key="id" wx:for-item="row">
          <text class="td td-rank">{{index + 1}}</text>
          <text class="td td-name">{{row.name}}</text>
          <text class="td td-all-days">{{row.daysUsed}}天</text>
          <text class="td td-all-cost t-{{row.costLevel}}">¥{{row.dailyCost}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- ===== 单个物品模式 ===== -->
  <block wx:else>
    <view class="item-header card">
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-tags">
          <text class="category-tag">{{item.category || '未分类'}}</text>
          <text class="price-tag">¥{{item.price}}</text>
        </view>
      </view>
      <view class="item-summary">
        <view class="summary-item">
          <text class="summary-num">{{item.daysUsed}}</text>
          <text class="summary-label">已用天数</text>
        </view>
        <view class="summary-divider"></view>
        <view class="summary-item">
          <text class="summary-num summary-cost">¥{{item.dailyCost}}</text>
          <text class="summary-label">当前日均</text>
        </view>
      </view>
    </view>

    <view class="chart-intro">
      <text class="intro-text">随着使用天数增加，每日均摊成本逐渐降低</text>
    </view>

    <view class="chart-wrapper card">
      <canvas type="2d" id="costChart" class="chart-canvas"></canvas>
    </view>

    <view class="footer-note">
      <text class="footer-text">📈 时间越长，每天成本越低 —— 多用用就回本了</text>
    </view>
  </block>

</view>
